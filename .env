# ============================================
# Email Notification Service — Environment
# ============================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API Service ---
API_PORT=3000
API_KEY=dev-api-key-change-in-production

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=notify_user
DB_PASSWORD=notify_password
DB_DATABASE=notification_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Email (Gmail SMTP) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=jalladvlogs@gmail.com
SMTP_PASS=xifviszvawvsanoi
EMAIL_FROM=jalladvlogs@gmail.com

# --- Retry ---
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=2000

# --- Queue ---
QUEUE_CONCURRENCY=5
